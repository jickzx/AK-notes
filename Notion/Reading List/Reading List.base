filters:
  and:
    - note["base"] == link("Reading List.base")
properties:
  file.name:
    displayName: Title
  Rating:
    displayName: Rating
  Category:
    displayName: Category
  Author:
    displayName: Author
  Status:
    displayName: Status
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Rating
      - Category
      - Author
      - Status
